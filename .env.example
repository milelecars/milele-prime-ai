# ── Telegram ───────────────────────────────────────────────────────────────
# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# ── Supabase ───────────────────────────────────────────────────────────────
# Project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=
# Service role key (server-side only — never expose to clients)
SUPABASE_SERVICE_KEY=

# ── Connectors ─────────────────────────────────────────────────────────────
# Use deterministic mock connectors instead of real APIs. Default: true.
# (true | false | 1 | 0 | yes | no | on | off)
USE_MOCK_CONNECTORS=true
# Optional connector wrapper tuning:
# CONNECTOR_CACHE_TTL_MS=15000
# CONNECTOR_MAX_RETRIES=3

# ── MT5 connector ──────────────────────────────────────────────────────────
# Required only when USE_MOCK_CONNECTORS=false.
MT5_API_URL=
MT5_API_KEY=

# ── Brokeret connector ─────────────────────────────────────────────────────
# Required only when USE_MOCK_CONNECTORS=false.
BROKERET_API_URL=
BROKERET_API_KEY=

# ── LLM (Claude / Anthropic) ───────────────────────────────────────────────
LLM_API_KEY=
# Optional model + generation config:
# LLM_MENTOR_MODEL=claude-opus-4-8
# LLM_CLASSIFIER_MODEL=claude-haiku-4-5
# LLM_MENTOR_MAX_TOKENS=1024
# LLM_MENTOR_EFFORT=medium   # low | medium | high | xhigh | max

# ── ElevenLabs (voice synthesis) ───────────────────────────────────────────
ELEVENLABS_API_KEY=
# "Milele mentor" voice id (required to send voice notes):
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ── Daily report (outbound) ────────────────────────────────────────────────
# DAILY_VOICE_ENABLED=true       # voice note on/off (default on)
# DAILY_REPORT_HOUR=7            # local hour to deliver (per-user timezone)
# DAILY_REPORT_GRANULARITY=weekly  # daily | weekly window for the metrics

# ── Marketing campaigns ────────────────────────────────────────────────────
# MARKETING_HOUR_LOCAL=10        # local hour to deliver marketing (per-user tz)
# MARKETING_WEEKLY_CAP=3         # max marketing messages per user per week

# ── Production hardening ───────────────────────────────────────────────────
# SYSTEM_HALT=false              # kill switch: halts ALL outbound + AI replies
# COST_GLOBAL_DAILY_USD=100      # global daily spend alert threshold (USD)
# COST_USER_DAILY_USD=5          # per-user daily hard ceiling (bronze base; tier-scaled)
# INBOUND_RATE_MAX=20            # max inbound messages per user per window
# INBOUND_RATE_WINDOW_MS=60000   # rate-limit window

# ── Inbound chat ───────────────────────────────────────────────────────────
# STT_PROVIDER=whisper           # whisper | deepgram (speech-to-text)
# OPENAI_API_KEY=                # required if STT_PROVIDER=whisper
# DEEPGRAM_API_KEY=              # required if STT_PROVIDER=deepgram
# CHAT_VOICE_EVERY_N=4           # voice a reply every Nth turn (0 disables)
# ESCALATION_CHAT_ID=            # internal Telegram chat id for handoff alerts

# ── Redis (BullMQ) ─────────────────────────────────────────────────────────
# e.g. redis://default:password@host:6379
REDIS_URL=

# ── Identity binding ───────────────────────────────────────────────────────
# Secret used to HMAC-sign identity connect tokens (>= 32 chars recommended)
IDENTITY_SIGNING_SECRET=
# Shared secret the Brokeret CRM presents to the internal link-minting endpoint
CRM_SHARED_SECRET=
# Bot username (without @) for building t.me deep links. Optional: falls back
# to the value Telegram returns once the bot is initialised.
# TELEGRAM_BOT_USERNAME=milele_prime_bot
# Connect-link lifetime in ms (default 900000 = 15 min):
# CONNECT_LINK_TTL_MS=900000

# ── Optional runtime config ────────────────────────────────────────────────
# NODE_ENV=development
# LOG_LEVEL=info
# PORT=3000
# Set to use webhook mode instead of long polling (production):
# TELEGRAM_WEBHOOK_URL=https://your-app.up.railway.app
