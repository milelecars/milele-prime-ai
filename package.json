{
  "name": "milele-prime-ai",
  "version": "0.1.0",
  "description": "Telegram bot backend for Milele Prime AI",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "prebuild": "npm run clean",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "node --env-file=tests/test.env --import tsx --test \"tests/**/*.test.ts\"",
    "audit:review": "tsx src/ops/audit-cli.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.69.0",
    "@supabase/supabase-js": "^2.45.4",
    "bullmq": "^5.12.0",
    "grammy": "^1.30.0",
    "ioredis": "5.10.1",
    "pdfmake": "^0.2.23",
    "pino": "^9.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.5.5",
    "@types/pdfmake": "^0.2.13",
    "pino-pretty": "^11.2.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
